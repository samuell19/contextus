{
  "name": "multiagent-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:shared && concurrently \"npm:dev:shared\" \"npm:dev:api\" \"npm:dev:web\"",
    "dev:shared": "npm --workspace @multiagent/shared run dev",
    "dev:api": "npm --workspace @multiagent/api run dev",
    "dev:web": "npm --workspace @multiagent/web run dev",
    "build:shared": "npm --workspace @multiagent/shared run build",
    "build:api": "npm --workspace @multiagent/api run build",
    "build:web": "npm --workspace @multiagent/web run build",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "test:shared": "npm --workspace @multiagent/shared run test",
    "test:api": "npm --workspace @multiagent/api run test",
    "test:web": "npm --workspace @multiagent/web run test",
    "test": "npm run build:shared && npm run test:shared && npm run test:api && npm run test:web",
    "db:migrate": "npm run build:shared && npm --workspace @multiagent/api run db:migrate"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}
