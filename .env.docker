# Runtime URLs
APP_URL=http://localhost:3000
WEB_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:8081
OPENROUTER_APP_URL=http://localhost:3000

# Database
DB_PORT=5432
DB_NAME=multiagent_platform
DB_USER=postgres
DB_PASSWORD=postgres

# Auth and encryption (required)
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-16
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-16
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
REFRESH_COOKIE_NAME=ma_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# OpenRouter (optional for boot, required to chat if user does not provide key)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_SUMMARY_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=Multiagent Platform

# Chat limits
CHAT_HISTORY_LIMIT=20
MAX_UPLOAD_SIZE_MB=5
WEB_PORT=8081
